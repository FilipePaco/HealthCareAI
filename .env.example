# Copie para .env e preencha. O .env NUNCA é versionado (está no .gitignore).

# --- LLM (provider-agnostic, P8) ---
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash-lite
GOOGLE_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Notícias ---
TAVILY_API_KEY=your-tavily-key-here

# --- Banco (Railway injeta automaticamente em produção) ---
DATABASE_URL=postgresql+psycopg2://srag:srag@localhost:5432/srag

# --- Segurança da API (P5) ---
API_KEY=change-me
CORS_ORIGINS=http://localhost:8501
RATE_LIMIT=30/minute

# --- Parâmetros das métricas (P7 — sem números mágicos) ---
REPORT_INCREASE_WINDOW_DAYS=14
NEWS_RECENCY_DAYS=30

# --- Agência de notícias (ADR-11) ---
NEWS_AGENT_MAX_ITERS=3            # nº máx. de iterações do laço de tool-calling
NEWS_RETRIEVE_K=6                 # top-k de notícias recuperadas pelo RAG

# --- Observabilidade de custo (P9/ADR-12) — tarifas estimadas em USD ---
LLM_INPUT_COST_PER_1M=0.10        # USD / 1M tokens de entrada
LLM_OUTPUT_COST_PER_1M=0.40       # USD / 1M tokens de saída
TAVILY_COST_PER_SEARCH=0.008      # USD / busca (free tier = 0)
