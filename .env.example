# Copie para .env e preencha. O .env NUNCA é versionado (está no .gitignore).

# --- LLM (provider-agnostic, P8) ---
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash-lite
GOOGLE_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Notícias ---
TAVILY_API_KEY=your-tavily-key-here

# --- Banco (Railway injeta automaticamente em produção) ---
DATABASE_URL=postgresql+psycopg2://srag:srag@localhost:5432/srag

# --- Segurança da API (P5) ---
API_KEY=change-me
CORS_ORIGINS=http://localhost:8501
RATE_LIMIT=30/minute

# --- Parâmetros das métricas (P7 — sem números mágicos) ---
REPORT_INCREASE_WINDOW_DAYS=14
NEWS_RECENCY_DAYS=30
